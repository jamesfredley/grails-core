{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": false
    },
    {
      "matchPackagePatterns": [
        "^org\\.seleniumhq\\.selenium"
      ],
      "groupName": "selenium monorepo"
    }
  ]
}
