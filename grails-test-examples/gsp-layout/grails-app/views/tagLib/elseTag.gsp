<!DOCTYPE html>
<html>
<head>
    <title>Else Tag Test</title>
</head>
<body>
    <h1>Else Tag Test</h1>
    <g:if test="${condition}">
        <div id="if-content">Condition is TRUE</div>
    </g:if>
    <g:else>
        <div id="else-content">Condition is FALSE</div>
    </g:else>
</body>
</html>
